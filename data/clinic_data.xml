<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Spécialités Médicales par défaut -->
        <record id="speciality_general" model="medical.speciality">
            <field name="name">Médecine Générale</field>
            <field name="code">MG</field>
            <field name="description">Médecine générale et soins primaires</field>
            <field name="average_duration">20</field>
            <field name="color">10</field>
        </record>

        <record id="speciality_cardio" model="medical.speciality">
            <field name="name">Cardiologie</field>
            <field name="code">CARD</field>
            <field name="description">Maladies du cœur et des vaisseaux sanguins</field>
            <field name="average_duration">45</field>
            <field name="color">1</field>
        </record>

        <record id="speciality_derma" model="medical.speciality">
            <field name="name">Dermatologie</field>
            <field name="code">DERM</field>
            <field name="description">Maladies de la peau, des cheveux et des ongles</field>
            <field name="average_duration">30</field>
            <field name="color">3</field>
        </record>

        <record id="speciality_pediatrie" model="medical.speciality">
            <field name="name">Pédiatrie</field>
            <field name="code">PED</field>
            <field name="description">Médecine des enfants et adolescents</field>
            <field name="average_duration">30</field>
            <field name="color">4</field>
        </record>

        <record id="speciality_gyneco" model="medical.speciality">
            <field name="name">Gynécologie</field>
            <field name="code">GYN</field>
            <field name="description">Santé de la femme et obstétrique</field>
            <field name="average_duration">30</field>
            <field name="color">6</field>
        </record>

        <record id="speciality_ophtalmo" model="medical.speciality">
            <field name="name">Ophtalmologie</field>
            <field name="code">OPHT</field>
            <field name="description">Maladies des yeux et de la vision</field>
            <field name="average_duration">25</field>
            <field name="color">7</field>
        </record>

        <record id="speciality_ortho" model="medical.speciality">
            <field name="name">Orthopédie</field>
            <field name="code">ORTH</field>
            <field name="description">Maladies des os, muscles et articulations</field>
            <field name="average_duration">40</field>
            <field name="color">2</field>
        </record>

        <record id="speciality_neuro" model="medical.speciality">
            <field name="name">Neurologie</field>
            <field name="code">NEUR</field>
            <field name="description">Maladies du système nerveux</field>
            <field name="average_duration">60</field>
            <field name="color">5</field>
        </record>

        <record id="speciality_endo" model="medical.speciality">
            <field name="name">Endocrinologie</field>
            <field name="code">ENDO</field>
            <field name="description">Maladies hormonales et du métabolisme</field>
            <field name="average_duration">45</field>
            <field name="color">8</field>
        </record>

        <record id="speciality_pneumo" model="medical.speciality">
            <field name="name">Pneumologie</field>
            <field name="code">PNEU</field>
            <field name="description">Maladies des poumons et des voies respiratoires</field>
            <field name="average_duration">40</field>
            <field name="color">9</field>
        </record>
    </data>
</odoo>
